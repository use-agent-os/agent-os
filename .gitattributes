*.sh text eol=lf

# Bundled BGE ONNX export used by memory's local embedder.
src/agentos/memory/models/bge_onnx/*.onnx filter=lfs diff=lfs merge=lfs -text
src/agentos/memory/models/bge_onnx/*.json text eol=lf
src/agentos/memory/models/bge_onnx/*.txt text eol=lf

# Bundled embedding exports (Pilot router MiniLM INT8 and any future model
# shipped under models/embeddings/{short}-int8). ONNX weights via LFS; the
# tokenizer/config sidecars stay text.
src/agentos/memory/models/embeddings/**/*.onnx filter=lfs diff=lfs merge=lfs -text
src/agentos/memory/models/embeddings/**/*.json text eol=lf
src/agentos/memory/models/embeddings/**/*.txt text eol=lf

# Pilot router (Rev 4) production bundle: self-trained model.onnx + manifest,
# guarded by required-files hydration assertions in the release workflows.
src/agentos/agentos_router/models/pilot_v1/*.onnx filter=lfs diff=lfs merge=lfs -text
src/agentos/agentos_router/models/pilot_v1/*.json text eol=lf
